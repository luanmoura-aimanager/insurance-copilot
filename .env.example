# Copy to .env and adjust as needed.
# Local dev points at the Postgres from docker-compose (host port 5433).
# Note the async driver: postgresql+asyncpg (not plain postgresql).
DATABASE_URL=postgresql+asyncpg://insurance:insurance@localhost:5433/insurance

# Read-only role (migration 4b285ffad59b) — used by the SQL worker / MCP query path.
# GRANT SELECT only; a write is physically impossible even if the text filter is bypassed.
# The password must match the RO_ROLE_PASSWORD used when the migration ran (put the real
# value only in .env, never here).
DATABASE_URL_RO=postgresql://insurance_ro:CHANGE_ME@localhost:5433/insurance
